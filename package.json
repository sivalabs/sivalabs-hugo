{
  "name": "sivalabs-hugo",
  "version": "1.0.0",
  "description": "SivaLabs Blog using Hugo SSG",
  "author": "SivaLabs",
  "license": "MIT",
  "scripts": {
    "build": "npm run hugo:build",
    "clean": "npm run hugo:clean",
    "serve": "npm run hugo:serve",
    "hugo:build": "hugo --gc --minify",
    "hugo:serve": "hugo server -D -F --disableFastRender",
    "hugo:clean": "rm -rf build resources public",
    "images:optimize": "node scripts/optimize-images.mjs",
    "dev": "npm run images:optimize && npm run hugo:serve"
  },
  "devDependencies": {
    "imagemin": "^9.0.1",
    "imagemin-webp": "^8.0.0",
    "js-yaml": "^4.2.0"
  }
}
